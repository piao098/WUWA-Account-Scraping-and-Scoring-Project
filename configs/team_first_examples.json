{
  "version": "pair-check-draft-2026-06-11",
  "notes": [
    "用于账号评分的配队完整度判断。",
    "3号位不绑定，只判断主C + 关键副C/体系辅助的核心二人组。",
    "owned_only 表示拥有该角色即视为配队条件满足，主要用于泛用辅助/通用增益。",
    "fixed_team 表示必须同时拥有 core_team 内 2 个角色才给完整配队加分。",
    "two_team 表示满足 core_teams 中任意一套二人组即可给完整配队加分。",
    "常驻五星、四星和漂泊者可作为配对条件出现，但不进入角色倍率计分。"
  ],
  "bonus_rules": {
    "owned_only_bonus": 4,
    "complete_fixed_team_bonus": 4,
